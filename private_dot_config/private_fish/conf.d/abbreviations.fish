if status is-interactive
    abbr -a cls clear
    abbr -a gs 'git status'
    abbr -a la 'eza -lah --icons --git'
    abbr -a ll 'eza -lah --icons --git'
    abbr -a ls 'eza --color --icons'
    abbr -a open xdg-open
    abbr -a cat bat
    abbr -a lg lazygit
    abbr -a v nvim
    abbr -a nvim-kickstart 'NVIM_APPNAME="nvim-kickstart" nvim'
    abbr -a gc 'git commit'
    abbr -a ga 'git add'
    abbr -a gcl 'git clone'
    abbr -a grep 'grep --color=auto'
    abbr -a rm 'trash -v'
end
